# 🔥 FIREBASE CONFIGURATION
# Get from: Firebase Console → Project Settings → Your Apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# 🔐 GOOGLE SIGN-IN
# Get from: Firebase Console → Authentication → Google → Web Client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# 🐙 GITHUB OAUTH
# Get from: GitHub → Settings → Developer Settings → OAuth Apps
EXPO_PUBLIC_GITHUB_CLIENT_ID=
EXPO_PUBLIC_GITHUB_REDIRECT_URI=your-app-scheme://oauth/callback
# Get after: firebase deploy --only functions
EXPO_PUBLIC_GITHUB_CLOUD_FUNCTION_URL=